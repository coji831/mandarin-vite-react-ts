{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/pre-tool-use.cjs",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node .github/hooks/user-prompt-submit.cjs",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/post-tool-use.cjs",
        "timeout": 20
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/stop.cjs",
        "timeout": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/session-start.cjs",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "node .github/hooks/subagent-start.cjs",
        "timeout": 10
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "node .github/hooks/subagent-stop.cjs",
        "timeout": 10
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node .github/hooks/pre-compact.cjs",
        "timeout": 10
      }
    ]
  }
}
