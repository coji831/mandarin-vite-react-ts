{
  "name": "mandarin-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=@mandarin/frontend",
    "dev:backend": "npm run dev --workspace=@mandarin/backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=@mandarin/frontend",
    "test": "npm run test --workspaces --if-present",
    "test:full": "npm run test:full --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "uuid": "^13.0.2"
  },
  "devDependencies": {
    "@google/design.md": "^0.3.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  }
}
