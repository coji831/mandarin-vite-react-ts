  "toneRules": [
    {
      "id": "rule-3rd-sandhi",
      "title": "3rd Tone Sandhi",
      "rule": "When two 3rd tones meet, the first becomes 2nd tone",
      "examples": [
        {
          "chinese": "你好",
          "dictionary": "nǐ hǎo",
          "spoken": "ní hǎo"
        },
        {
          "chinese": "很好",
