{
  "name": "@mandarin/backend",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/app/index.ts",
    "start": "node dist/app/index.js",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/shared/docs/openapi.yaml', 'dist/shared/docs/openapi.yaml')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --changed",
    "test:full": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:db": "vitest run tests/integration/database.test.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed:content-index": "node scripts/seed-content-index.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@mandarin/shared-constants": "*",
    "@mandarin/shared-types": "*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.11.1",
    "js-yaml": "^4.3.0",
    "jsonwebtoken": "^9.0.3",
    "md5": "^2.3.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.1"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/cors": "^2.8.19",
    "@types/js-yaml": "^4.0.9",
    "@types/md5": "^2.3.5",
    "@types/node": "^24.7.2",
    "@types/node-fetch": "^3.0.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "ioredis-mock": "^8.13.1",
    "supertest": "^7.2.2",
    "testcontainers": "^11.11.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
