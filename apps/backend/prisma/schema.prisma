generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  progress            Progress[]
  sessions            Session[]
  customLists         VocabularyList[]

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Progress {
  id           String   @id @default(uuid())
  userId       String
  wordId       String
  studyCount   Int      @default(0)
  correctCount Int      @default(0)
  confidence   Float    @default(0)
  nextReview   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  currentDelay Int?
  lapseCount   Int      @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
  @@index([nextReview])
  @@index([userId, nextReview])
  @@index([userId, lapseCount])
}

model VocabularyWord {
  id              String         @id
  traditional     String
  simplified      String
  pinyin          String
  english         String
  exampleSentence String?
  audioUrl        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
  categories      WordCategory[]
  lists           WordList[]

  @@index([pinyin])
  @@index([simplified])
}

model Category {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  icon         String?
  displayOrder Int?
  words        WordCategory[]

  @@index([name])
}

model VocabularyList {
  id          String     @id
  name        String
  description String?
  difficulty  String?
  isPublic    Boolean    @default(true)
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  creator     User?      @relation(fields: [createdBy], references: [id])
  words       WordList[]

  @@index([difficulty])
  @@index([createdBy])
}

model WordCategory {
  wordId     String
  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  word       VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([wordId, categoryId])
  @@index([categoryId])
}

model WordList {
  wordId    String
  listId    String
  sortOrder Int?
  addedAt   DateTime       @default(now())
  list      VocabularyList @relation(fields: [listId], references: [id], onDelete: Cascade)
  word      VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([wordId, listId])
  @@index([listId, sortOrder])
}

model FoundationProgress {
  id            String   @id @default(uuid())
  userId        String
  sectionId     String   // "pinyin" | "tones" | "strokes" | "animations"
  completed     Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, sectionId])
  @@index([userId])
}

model PhaseGate {
  id                  String   @id @default(uuid())
  userId              String   @unique
  currentPhase        Int      @default(1)
  phase1Passed        Boolean  @default(false)
  phase2Passed        Boolean  @default(false)
  phase3Passed        Boolean  @default(false)
  phase4Unlocked      Boolean  @default(false)
  qualificationScore  Int?     // Placement quiz score
  placedPhase         Int?     // Phase assigned by qualification
  phase1Retention     Float?   // Retention rate for phase 1
  phase2Retention     Float?   // Retention rate for phase 2
  phase3Retention     Float?   // Retention rate for phase 3
  gateCriteria        String?  // "quiz" | "retention" | "both"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  quizType    String   // "audio-to-type"
  phase       Int?     // 1 | 2 | 3 | 0 (qualification)
  totalScore  Int      @default(0)
  maxScore    Int      @default(20)
  passed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  answers QuizAttemptAnswer[]

  @@index([userId, quizType])
  @@index([userId])
}

model QuizAttemptAnswer {
  id             String  @id @default(uuid())
  attemptId      String
  questionIndex  Int
  pinyinInput    String
  selectedTone   Int
  correctPinyin  String
  correctTone    Int
  correct        Boolean
  category       String

  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model StudyStreak {
  id               String   @id @default(uuid())
  userId           String   @unique
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime @default(now())
  freezeCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}// ── ReviewItem: Phase 1 review tracking (flip-card SRS) ──
// Tracks study progress for pinyin, tones, and stroke reference items.
// Uses simple interval doubling (not full SM-2) — Phase 1 is introductory.
model ReviewItem {
  id            String   @id @default(uuid())
  userId        String
  itemType      String   // "pinyin-initial" | "pinyin-final" | "pinyin-combination" | "tone-identification" | "tone-pair" | "tone-rule" | "stroke-reference" | "pinyin-syllable" | "tone-syllable"
  itemId        String   // identifier within the type (e.g., "b", "ao", "mā", "3rd+3rd")
  front         String?  // Display text for the front of the flip-card
  back          String?  // Display text for the back of the flip-card (answer)
  category      String?  // Grouping category: "pinyin" | "tones" | "strokes"
  studyCount    Int      @default(0)
  correctCount  Int      @default(0)
  lastReviewed  DateTime?
  nextReview    DateTime @default(now())
  intervalDays  Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, itemType, itemId])
  @@index([userId, nextReview])
}
