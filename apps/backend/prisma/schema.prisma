// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  sessions     Session[]
  progress     Progress[]
  customLists  VocabularyList[]

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Progress {
  id           String   @id @default(uuid())
  userId       String
  wordId       String
  studyCount   Int      @default(0)
  correctCount Int      @default(0)
  confidence   Float    @default(0)
  nextReview   DateTime @default(now())
  lapseCount   Int      @default(0)
  currentDelay Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
  @@index([nextReview])
  @@index([userId, nextReview])
  @@index([userId, lapseCount])
}

model VocabularyWord {
  id              String   @id
  traditional     String
  simplified      String
  pinyin          String
  english         String
  exampleSentence String?
  audioUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  categories WordCategory[]
  lists      WordList[]

  @@index([pinyin])
  @@index([simplified])
}

model Category {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  icon         String?
  displayOrder Int?

  words WordCategory[]

  @@index([name])
}

model VocabularyList {
  id          String   @id
  name        String
  description String?
  difficulty  String?
  isPublic    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  words   WordList[]
  creator User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([difficulty])
  @@index([createdBy])
}

model WordCategory {
  wordId     String
  categoryId String

  word     VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([wordId, categoryId])
  @@index([categoryId])
}

model WordList {
  wordId    String
  listId    String
  sortOrder Int?
  addedAt   DateTime @default(now())

  word VocabularyWord  @relation(fields: [wordId], references: [id], onDelete: Cascade)
  list VocabularyList  @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([wordId, listId])
  @@index([listId, sortOrder])
}

model StudyStreak {
  id               String   @id @default(uuid())
  userId           String   @unique
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime @default(now())
  freezeCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model QuizResult {
  id           String   @id @default(uuid())
  userId       String
  wordId       String
  correct      Boolean
  questionType String
  timeSpentMs  Int?
  answeredAt   DateTime @default(now())

  @@index([userId, wordId])
  @@index([userId, answeredAt])
}
