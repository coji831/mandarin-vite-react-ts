# Example environment variables for backend (add to .env.local)

# HMAC key used to derive cache object names for examples (hex/opaque)
# IMPORTANT: Provision this via Secret Manager or Kubernetes Secret; rotate regularly (90 days recommended)
EXAMPLES_CACHE_HMAC_KEY=[REDACTED]

# Optional previous HMAC key to allow dual-key reads during rotation
EXAMPLES_CACHE_HMAC_KEY_PREVIOUS=[REDACTED]
