{
  "name": "@mandarin/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run --changed",
    "test:full": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@mandarin/shared-constants": "*",
    "@mandarin/shared-types": "*",
    "axios": "^1.18.0",
    "hanzi-writer": "^3.7.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.18.1",
    "react-router-dom": "^7.8.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.31.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
